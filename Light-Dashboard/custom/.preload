
-- Load the Mini Content Management System (CMS)
-- We call cmsOnunload when app is stopped
local cmsOnunload=io:dofile(".lua/cms.lua",app)

trace"Starting CMS SMQ broker"

local smq -- Broker set below
local angle=0 -- 0 to 180
local rpcInterface={}

local function newClient(tid)
   trace"New SMQ client"
end

local function clientDisconnected(tid)
   trace"SMQ client disconnected"
end

smq = require"smq.hub".create{onconnect=newClient,onclose=clientDisconnected}

local function registerRpcMethod(name, callback)
   rpcInterface[name]=callback
end

local function rpcError(message)
   return {rsp=nil,err=message or "RPC failed"}
end

-- RPC handler
smq:subscribe("self",{subtopic="$RpcReq",json=true,onmsg=function(request,ptid)
   if "table" ~= type(request) then
      smq:publish(rpcError"Invalid RPC request",ptid,"$RpcResp")
      return
   end

   local id=request.id
   local name=request.name
   local args=request.args or {}

   if nil == id or "string" ~= type(name) or "table" ~= type(args) then
      smq:publish({id=id,err="Invalid RPC request"},ptid,"$RpcResp")
      return
   end

   local callback=rpcInterface[name]
   if not callback then
      smq:publish({id=id,err="RPC function not found"},ptid,"$RpcResp")
      return
   end

   local ok,rsp,err=pcall(callback,table.unpack(args))
   if not ok then
      err=rsp
      rsp=nil
   elseif nil ~= rsp then
      err=nil
   end

   smq:publish({id=id,rsp=rsp,err=err},ptid,"$RpcResp")
end})

-- Demo handlers used by .lua/www/RoundSlider.html.
smq:subscribe("self",{subtopic="setSlider",json=true,onmsg=function(data)
   if "table" == type(data) and "number" == type(data.angle) then
      angle=math.max(0,math.min(180,math.floor(data.angle)))
      trace("Slider angle",angle)
      smq:publish({angle=angle},"slider")
   end
end})

smq:subscribe("self",{subtopic="getSlider",onmsg=function(data,ptid)
   -- Update new client with current angle pos.
   smq:publish({angle=angle},ptid,"slider")
end})

-- Example page-specific RPC method. Add product/page methods here or register
-- them from broker modules loaded by this preload script.
registerRpcMethod("echo",function(...)
   return {...}
end)

registerRpcMethod("multiply",function(a,b)
   if "number" ~= type(a) or "number" ~= type(b) then
      return nil,"multiply expects two numbers"
   end
   return a * b
end)

registerRpcMethod("failfunc",function()
   return nil,"this function fails"
end)

registerRpcMethod("serverInfo",function()
   return {
      app="Light Dashboard",
      variant="custom",
      rpc=true
   }
end)

registerRpcMethod("getSliderAngle",function()
   return {angle=angle}
end)

-- SMQ/index.lsp calls this function when a browser client connects.
function connectSmqClient(cmd)
   smq:connect(cmd)
end

-- Run when app is stopped
function onunload()
   cmsOnunload()
   smq:shutdown()
end
