{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LSP Examples AI Index",
  "type": "object",
  "required": [
    "version",
    "repository",
    "purpose",
    "examples"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "repository": {
      "type": "object",
      "required": [
        "owner",
        "name",
        "branch"
      ],
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        }
      }
    },
    "purpose": {
      "type": "string"
    },
    "examples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/example"
      }
    }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "required": [
        "mako",
        "xedge",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "mako": {
          "enum": [
            "compatible",
            "partial",
            "not-applicable",
            "unknown"
          ]
        },
        "xedge": {
          "enum": [
            "compatible",
            "partial",
            "not-applicable",
            "unknown"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "appRoot": {
      "type": "object",
      "required": [
        "appRootPath",
        "label",
        "run",
        "summary",
        "importantFiles",
        "omitFromCompactContext"
      ],
      "additionalProperties": false,
      "properties": {
        "appRootPath": {
          "$ref": "#/$defs/repoPath"
        },
        "label": {
          "type": "string"
        },
        "run": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "importantFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repoPath"
          }
        },
        "omitFromCompactContext": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "example": {
      "type": "object",
      "required": [
        "examplePath",
        "title",
        "summary",
        "tags",
        "goodFor",
        "notFor",
        "runtime",
        "appRoots",
        "readme",
        "rawReadmeUrl"
      ],
      "additionalProperties": false,
      "properties": {
        "examplePath": {
          "$ref": "#/$defs/repoPath"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "goodFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtime": {
          "$ref": "#/$defs/runtime"
        },
        "appRoots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/appRoot"
          }
        },
        "readme": {
          "$ref": "#/$defs/repoPath"
        },
        "rawReadmeUrl": {
          "type": "string"
        }
      }
    },
    "repoPath": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\).+"
    }
  }
}

