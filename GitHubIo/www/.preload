mako.createloader(io)

error"Oops, you forgot to edit www/.preload: Add your GIT repo details below and delete this code line"

local ghio = require"GitHubIo".create{
   owner  = "REPO-OWNER", -- e.g. RealTimeLogic
   repo   = "REPO-NAME", -- e,g, LSP-Examples
   token  = "GITHUB-TOKEN", -- Required for write access, but not for read if repo is public
   branch = "master", -- typically master or main
   log=function(url,code,message) trace(url,code,message) end,
   mtime=os.time()
}

-- Create a WebDAV/Web-File-Manager and attach the GitHub IO
require"wfs" -- Install function ba.create.wfs
fs=ba.create.wfs("git", ghio, ".LOCK")
fs:insert()

print"GitHubIo test: Navigate to http://localhost/git/"
